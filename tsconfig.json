{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "esModuleInterop": true
  }
}